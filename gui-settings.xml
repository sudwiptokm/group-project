<?xml version="1.0" encoding="UTF-8"?>
<!--
    sumo-gui view settings for the heterogeneous-traffic intersection.

    Wired into intersection.sumocfg via <gui-only><gui-settings-file>.
    Purpose: make the sim readable and demo-ready:
      - vehicleQuality=2  -> draw real guiShape silhouettes (moto / moped / sedan)
      - vehicles coloured "by type" -> uses each vType's color= (orange/blue/grey)
      - size exaggeration so small 2/3-wheelers stay visible when zoomed out
      - dark clean background, lane borders + link rules on, junction shapes drawn
      - <delay> slows playback for smooth, watchable motion (raise if still fast)

    Missing scheme attributes fall back to SUMO defaults (tolerated by 1.27).
-->
<viewsettings>
    <scheme name="hetero-demo">

        <opengl dither="1" fps="1" drawBoundaries="0"
                forceDrawForPositionSelection="0"
                forceDrawForRectangleSelection="0"/>

        <background backgroundColor="34,38,46"
                    showGrid="0" gridXSize="100.00" gridYSize="100.00"/>

        <edges laneEdgeMode="0" laneShowBorders="1" showBikeMarkings="1"
               showLinkDecals="1" showLinkRules="1" showRails="1"
               hideConnectors="0" widthExaggeration="1.00" minSize="1.00"
               showLaneDirection="1" showSublanes="1" spreadSuperposed="0">
            <colorScheme name="uniform">
                <entry color="60,64,72" name="road"/>
            </colorScheme>
        </edges>

        <vehicles vehicleQuality="2" showBlinker="1" drawMinGap="0"
                  showBTRange="0" showRouteIndex="0" scaleLength="1"
                  showParkingInfo="0"
                  vehicleSize.minSize="2.00" vehicleSize.exaggeration="1.30">
            <colorScheme name="by type"/>
        </vehicles>

        <persons personQuality="2"
                 personSize.minSize="1.00" personSize.exaggeration="1.00"/>

        <junctions junctionMode="0" drawShape="1" drawCrossingsAndWalkingareas="1"
                   junctionSize.minSize="1.00" junctionSize.exaggeration="1.00"
                   showLane2Lane="0" showJunctionIndex="0" showInternalJunctionIndex="0">
            <colorScheme name="uniform">
                <entry color="46,50,58" name="junction"/>
            </colorScheme>
        </junctions>

        <additionals addMode="0"
                     addSize.minSize="1.00" addSize.exaggeration="1.00"/>

        <pois poiSize.minSize="0.00" poiSize.exaggeration="5.00"/>
        <polys polySize.minSize="0.00" polySize.exaggeration="1.00"/>

        <legend showSizeLegend="1" showColorLegend="0" showVehicleColorLegend="1"/>
    </scheme>

    <delay value="80"/>
</viewsettings>
